{
  "name": "gray-area",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "npm run build && npm start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4",
    "socket.io": "^4",
    "zod": "^3",
    "tsx": "^4"
  },
  "devDependencies": {
    "@types/express": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "concurrently": "^8",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "react-router-dom": "^6",
    "socket.io-client": "^4",
    "tailwindcss": "^3",
    "typescript": "^5",
    "vite": "^5",
    "vitest": "^1"
  }
}
